# Database
PG_HOST=localhost
PG_PORT=5432
PG_DB=parkguidesg
PG_USER=postgres
PG_PASSWORD=your_password_here

# API endpoints (defaults are public data.gov.sg)
HDB_API_URL=https://api.data.gov.sg/v1/transport/carpark-availability
NEA_API_URL=https://api.data.gov.sg/v1/environment/2-hour-weather-forecast

# ETL tuning
FETCH_INTERVAL=300
RESAMPLE_MINUTES=15
RETENTION_DAYS=90
